{
  "manifest_version": 3,
  "name": "Ghost Job Detector",
  "version": "1.0",
  "description": "Detect ghost jobs on LinkedIn, Indeed, and more",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon.png" }
  },
  "content_scripts": [{
    "matches": ["https://*.linkedin.com/*", "https://*.indeed.com/*"],
    "js": ["content.js"]
  }],
  "background": { "service_worker": "background.js" }
}